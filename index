    .tools {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) auto;
      gap: 12px;
      align-items: center;
    }
    input[type="search"] {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 11px 12px;
      font-size: 15px;
      background: #fff;
      color: var(--ink);
    }
    .count { color: var(--muted); font-size: 14px; white-space: nowrap; }
    main { padding: 24px; }
    .note {
      background: #fff8e6;
      border: 1px solid #f3d58b;
      color: var(--warn);
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 18px;
      font-size: 14px;
    }
    .chips {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 0 0 18px;
    }
    .chip {
      border: 1px solid var(--line);
      background: var(--panel);
      color: var(--ink);
      border-radius: 999px;
      padding: 7px 11px;
      cursor: pointer;
      font-size: 13px;
    }
    .chip.active {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }
    section {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      margin: 0 0 18px;
      overflow: hidden;
    }
    h2 {
      margin: 0;
      padding: 14px 16px;
      background: #edf3f2;
      border-bottom: 1px solid var(--line);
      font-size: 18px;
      letter-spacing: 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }
    th, td {
      padding: 11px 12px;
      border-bottom: 1px solid var(--line);
      vertical-align: top;
      word-break: break-word;
    }
    th {
      background: #f8fafb;
      text-align: left;
      color: #435061;
      font-size: 13px;
      font-weight: 700;
    }
    tr:last-child td { border-bottom: 0; }
    td.en { font-weight: 650; color: #162232; }
    td.cn { color: #1c3b36; }
    td.note-cell { color: var(--muted); font-size: 14px; }
    .tag {
      display: inline-block;
      background: var(--tag);
      color: #485466;
      border-radius: 6px;
      padding: 1px 6px;
      font-size: 12px;
      margin-left: 6px;
      vertical-align: 1px;
    }
    .hidden { display: none; }
    footer { color: var(--muted); font-size: 13px; padding: 4px 0 28px; }
    @media (max-width: 760px) {
      h1 { font-size: 24px; }
      .tools { grid-template-columns: 1fr; }
      table, thead, tbody, tr, th, td { display: block; width: 100%; }
      thead { display: none; }
      tr { border-bottom: 1px solid var(--line); }
      tr:last-child { border-bottom: 0; }
      td { border-bottom: 0; padding: 7px 12px; }
      td::before {
        display: block;
        color: var(--muted);
        font-size: 12px;
        font-weight: 700;
      }
      td.en::before { content: "English"; }
      td.cn::before { content: "中文"; }
      td.note-cell::before { content: "学习提示"; }
