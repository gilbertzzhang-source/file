    const content = document.getElementById("content");
    const chips = document.getElementById("chips");
    const q = document.getElementById("q");
    const shown = document.getElementById("shown");
    const total = document.getElementById("total");
    let activeGroup = "全部";

    function render() {
      chips.innerHTML = "";
      ["全部", ...groups.map(g => g.name)].forEach(name => {
        const btn = document.createElement("button");
        btn.className = "chip" + (name === activeGroup ? " active" : "");
        btn.textContent = name;
        btn.addEventListener("click", () => {
          activeGroup = name;
          render();
        });
        chips.appendChild(btn);
      });

      content.innerHTML = "";
      let totalRows = 0;
      let visibleRows = 0;
      const needle = q.value.trim().toLowerCase();

      groups.forEach(group => {
        const section = document.createElement("section");
        const h2 = document.createElement("h2");
        h2.textContent = group.name;
        const table = document.createElement("table");
        table.innerHTML = "<thead><tr><th>English</th><th>中文</th><th>学习提示</th></tr></thead><tbody></tbody>";
        const tbody = table.querySelector("tbody");
        let groupVisible = 0;

        group.terms.forEach(([en, cn, note]) => {
          totalRows += 1;
          const text = `${group.name} ${en} ${cn} ${note}`.toLowerCase();
          const okGroup = activeGroup === "全部" || activeGroup === group.name;
          const okSearch = !needle || text.includes(needle);
          if (!okGroup || !okSearch) return;
          groupVisible += 1;
          visibleRows += 1;
          const tr = document.createElement("tr");
          tr.innerHTML = `<td class="en">${escapeHtml(en)}</td><td class="cn">${escapeHtml(cn)}</td><td class="note-cell">${escapeHtml(note)}</td>`;
          tbody.appendChild(tr);
        });

        if (groupVisible > 0) {
          section.appendChild(h2);
          section.appendChild(table);
          content.appendChild(section);
        }
      });

      total.textContent = totalRows;
      shown.textContent = visibleRows;
    }

    function escapeHtml(value) {
      return value.replace(/[&<>"']/g, char => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        "\"": "&quot;",
        "'": "&#039;"
      }[char]));
    }

    q.addEventListener("input", render);
    render();
  </script>
